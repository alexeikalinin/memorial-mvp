# Скопируйте в .env и подставьте свои значения.
# Для деплоя (Railway/Render и т.д.) задайте эти переменные в настройках сервиса.

# База данных (локально SQLite, прод — Supabase PostgreSQL pooler)
DATABASE_URL=sqlite:///./memorial.db

# Supabase (для S3 Storage и endpoint)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# S3-совместимое хранилище (Supabase Storage: ключи в Dashboard → Storage → S3 Access Keys)
USE_S3=false
S3_BUCKET_NAME=memorial-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_REGION=eu-central-1

# CORS: домен фронта на Vercel (добавьте свой backend URL при деплое)
CORS_ORIGINS=http://localhost:5173,https://memorial-mvp.vercel.app,https://memorial-mvp-*.vercel.app

# Публичный URL этого backend (для webhook'ов, QR и т.д.)
PUBLIC_API_URL=https://YOUR_BACKEND_URL
# Публичные ссылки (QR, инвайты): база фронта. Если SPA на Vercel в подкаталоге /app — добавьте /app
PUBLIC_FRONTEND_URL=https://memorial-mvp.vercel.app/app

# Редирект после Google OAuth (должен совпадать с тем, куда открывается /auth/callback в SPA)
FRONTEND_URL=http://localhost:5173
# Прод (Vercel, схема landing + /app): FRONTEND_URL=https://memorial-mvp.vercel.app/app

# Секрет (минимум 32 символа в продакшене)
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars

# Глобальные админы (emails через запятую): полные права owner на все мемориалы через API
# без строк в memorial_access. Для аудита в БД см. grant_owner_all_memorials.py
# GLOBAL_ADMIN_EMAILS=operator@example.com

# Режим демо для инвестора: любой залогиненный пользователь = owner на всех мемориалах.
# Выключите до реального запуска. Опционально: python set_all_memorials_public.py
# INVESTOR_DEMO_MODE=false

# OpenAI — для чата с аватаром и RAG
OPENAI_API_KEY=
# Модель чата (дефолт в коде: gpt-4o-mini). Не задавайте gpt-4-turbo-preview — снята с API (404).
# OPENAI_MODEL=gpt-4o-mini

# Векторная БД (RAG для чата с аватаром)
# Локально: файловый режим (без Docker)
# VECTOR_DB_PROVIDER=qdrant
# QDRANT_LOCAL_PATH=./qdrant_storage
#
# Прод через Dockerfile (Railway, root=backend): образ уже задаёт QDRANT_LOCAL_PATH=/data/qdrant_storage
# (встроенный Qdrant, отдельный сервис не нужен). Для векторов между деплоями — Volume на /data.
#
# Альтернатива: Qdrant Cloud — тогда QDRANT_LOCAL_PATH оставьте пустым и задайте:
# QDRANT_URL=https://xxxx.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=eyJ...

# Опционально: озвучка и анимация
# ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Голос по умолчанию (Rachel — женский)
# ELEVENLABS_VOICE_ID_MALE=pNInz6obpgDQGcFmaJgB   # Мужской (Adam) — для мемориалов с полом «мужской»
# ELEVENLABS_VOICE_ID_FEMALE=21m00Tcm4TlvDq8ikWAM  # Женский (Rachel) — для мемориалов с полом «женский»
# USE_HEYGEN=true
# HEYGEN_API_KEY=

# Telegram Bot (получить токен у @BotFather)
# TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_BOT_USERNAME=MemorialBot   # без @
# BOT_API_BASE_URL=http://localhost:8000/api/v1
