# Скопируйте в .env.local для локальной разработки.
# Для Vercel задайте переменную в Project Settings → Environment Variables.

# URL бэкенда с путём API (без слеша в конце)
# Пример: https://memorial-api.railway.app/api/v1
VITE_API_URL=https://YOUR_BACKEND_URL/api/v1

# Опционально: отдельный URL для waitlist на статическом лендинге (корень dist/).
# Если не задан, при npm run build подставляется VITE_API_URL (см. vite.config.js).
# VITE_LANDING_API_URL=https://YOUR_BACKEND_URL/api/v1
